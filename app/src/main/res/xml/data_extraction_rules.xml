<?xml version="1.0" encoding="utf-8"?><!-- API 31+ equivalent of backup_rules.xml — governs both cloud backup and device-to-device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="sharedpref"
            path="shellify_crypto.xml" />
        <exclude
            domain="file"
            path="../datastore/pwa_password.preferences_pb" />
        <exclude
            domain="file"
            path="../datastore/pwa_cookie_store.preferences_pb" />
        <exclude
            domain="file"
            path="../datastore/pwa_backup.preferences_pb" />
        <exclude
            domain="database"
            path="shellify.db" />
        <exclude
            domain="database"
            path="shellify.db-shm" />
        <exclude
            domain="database"
            path="shellify.db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="sharedpref"
            path="shellify_crypto.xml" />
        <exclude
            domain="file"
            path="../datastore/pwa_password.preferences_pb" />
        <exclude
            domain="file"
            path="../datastore/pwa_cookie_store.preferences_pb" />
        <exclude
            domain="file"
            path="../datastore/pwa_backup.preferences_pb" />
        <exclude
            domain="database"
            path="shellify.db" />
        <exclude
            domain="database"
            path="shellify.db-shm" />
        <exclude
            domain="database"
            path="shellify.db-wal" />
    </device-transfer>
</data-extraction-rules>
